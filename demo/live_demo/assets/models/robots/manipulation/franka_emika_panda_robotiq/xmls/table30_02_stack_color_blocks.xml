<mujoco model="panda_stack_cubes">
  <!-- Robot -->
  <include file="panda_robotiq.xml"/>

  <statistic center="0.5 0 0.2" extent="0.8"/>

  <option timestep="0.002" iterations="100" ls_iterations="20" integrator="implicitfast">
    <flag eulerdamp="disable"/>
  </option>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="120" elevation="-20"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.2"/>

    <mesh name="cube_blue_mesh"   file="../../../../../tasks/table30/_02_stack_color_blocks/meshes/blue_plastic_cube/blue_plastic_cube.obj"/>
    <mesh name="cube_yellow_mesh" file="../../../../../tasks/table30/_02_stack_color_blocks/meshes/yellow_plastic_cube/yellow_plastic_cube.obj"/>
    <mesh name="cube_orange_mesh" file="../../../../../tasks/table30/_02_stack_color_blocks/meshes/orange_plastic_cube/orange_plastic_cube.obj"/>

    <material name="cube_blue_mat"   rgba="0.10 0.35 0.95 1" reflectance="0.2"/>
    <material name="cube_yellow_mat" rgba="0.95 0.85 0.10 1" reflectance="0.2"/>
    <material name="cube_orange_mat" rgba="0.95 0.55 0.10 1" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light pos="0 0 1.5" dir="0 0 -1" directional="true"/>
    
    <!-- <camera fovy="43.365" name="front" pos="1.516 0.044 1.111" xyaxes="-0.043 0.999 -0.000 -0.551 -0.023 0.834"/> -->
    <camera fovy="43.36" name="front" pos="1.070 0.029 0.747" xyaxes="-0.109 0.993 0.038 -0.659 -0.101 0.745"/>
    <geom name="range" type="box" pos="0.5 0.02 0.055" size="0.125 0.225 0.001" quat="1 0 0 0.02" contype="0" conaffinity="0" rgba="0 1 1 0.2"/>

    <geom name="floor" size="0 0 0.05" type="plane" material="groundplane" contype="1"/>
    <geom name="table" pos="0.45 0.06 0.0442" quat="1 0 0 0.02" size="0.33 0.525 0.01" type="box" contype="1" rgba="0.6 0.6 0.6 1"/>
    <body name="cube_blue" pos="0.497742 -0.100449 0.08" >
      <joint type="free" frictionloss="0.0001"/>
      <geom name="cube_blue_vis" type="mesh" mesh="cube_blue_mesh" material="cube_blue_mat" contype="0" conaffinity="0"/>
      <geom name="cube_blue_box" type="box" size="0.025 0.025 0.025" rgba="1 0 0 1"  contype="1" conaffinity="1" group="3"/>
      <site name="cube_blue_center" pos="0 0 0" type="box" size="0.03 0.03 0.02"  rgba="1 0 0 0.6" group="4"/>
    </body>

    <body name="cube_yellow" pos="0.5145 0.0267 0.8">
        <joint type="free" frictionloss="0.0001"/>
        <geom name="cube_yellow_vis" type="mesh" mesh="cube_yellow_mesh" material="cube_yellow_mat" contype="0" conaffinity="0"/>
        <geom name="cube_yellow_box" type="box" size="0.025 0.025 0.025" rgba="1 0 0 1" contype="1" conaffinity="1" group="3"/>
        <site name="cube_yellow_center" pos="0 0 0" type="box" size="0.03 0.03 0.02" rgba="1 1 1 1" group="4"/>
    </body>

    <body name="cube_orange" pos="0.5230 0.1418 0.8" >
      <joint type="free" frictionloss="0.0001"/>
      <geom name="cube_orange_vis" type="mesh" mesh="cube_orange_mesh" material="cube_orange_mat" contype="0" conaffinity="0"/>
      <geom name="cube_orange_box" type="box" size="0.025 0.025 0.025" rgba="1 0 0 1" contype="1" conaffinity="1" group="3"/>
      <site name="cube_orange_center" pos="0 0 0" type="box" size="0.03 0.03 0.02" rgba="1 1 1 1" group="4"/>
    </body>

    <site name="place_target_A" pos="0.38 -0.185 0.1" size="0.01" type="sphere" rgba="0.2 0.8 0.2 0.6" group="4"/>
    <site name="place_target_B" pos="0.38  0.215 0.1" size="0.01" type="sphere" rgba="0.2 0.8 0.2 0.6" group="4"/>

    <!-- Keep mocap_target -->
